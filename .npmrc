# pnpm configuration — supply-chain security hardening.
# https://pnpm.io/npmrc

# Strictness — fail fast on inconsistencies.
auto-install-peers=true
strict-peer-dependencies=true
resolution-mode=highest

# Reproducibility — never silently update lockfile in CI.
prefer-frozen-lockfile=true

# Supply-chain protection: do NOT execute postinstall/prepare scripts from
# untrusted dependencies by default. Whitelist trusted ones via the
# `onlyBuiltDependencies` array in package.json or `pnpm approve-builds`.
# (Comment this out if your toolchain has native deps that need building.)
# ignore-scripts=true

# Block installing very fresh releases — gives the ecosystem time to detect
# malicious publishes (pnpm 10+).
# minimum-release-age=1440

# Verify the integrity of the global content-addressable store.
verify-store-integrity=true
