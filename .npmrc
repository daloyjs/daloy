# DaloyJS root npm/pnpm config — supply-chain hardening.
#
# These defaults apply to anyone working in this repo (maintainers, CI,
# contributors). They mirror — and where possible exceed — the guidance in
# otherdocs/security-incidence.md.
#
# Values are deliberately strict. Override locally only with a justification.

# ---------------------------------------------------------------------------
# Lifecycle scripts
# ---------------------------------------------------------------------------
# Reject postinstall / preinstall / prepare hooks from transitive deps. This
# is the primary execution channel used by the chalk/debug, node-ipc, and
# Shai-Hulud worm campaigns. pnpm's `onlyBuiltDependencies` (set in
# package.json) is the explicit allowlist for the few packages we *do* let
# run scripts.
ignore-scripts=true

# ---------------------------------------------------------------------------
# Install integrity
# ---------------------------------------------------------------------------
# Frozen lockfile + verified store. CI re-checks this on every run.
frozen-lockfile=true
verify-store-integrity=true
prefer-frozen-lockfile=true

# Fail closed on missing peer deps instead of silently picking versions.
strict-peer-dependencies=true

# Forbid auto-installing peer deps; we want explicit control.
auto-install-peers=false

# ---------------------------------------------------------------------------
# Release-age cooldown (pnpm 10+)
# ---------------------------------------------------------------------------
# Wait 24h (1440 minutes) before installing a freshly published version.
# Fast-moving npm worm campaigns are typically detected and unpublished
# within hours; this window is what lets us avoid them by default. Override
# only with an explicit `--minimum-release-age=0` for an emergency hotfix.
minimum-release-age=1440

# ---------------------------------------------------------------------------
# Registry posture
# ---------------------------------------------------------------------------
registry=https://registry.npmjs.org/

# Refuse to upload anything without provenance metadata when publishing.
provenance=true

# ---------------------------------------------------------------------------
# Audit
# ---------------------------------------------------------------------------
audit-level=moderate
fund=false
